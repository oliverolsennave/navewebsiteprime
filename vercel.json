{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)\\.pkpass",
      "headers": [
        { "key": "Content-Type", "value": "application/vnd.apple.pkpass" }
      ]
    },
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ],
  "functions": {
    "api/stripe-webhook.js": {
      "maxDuration": 30
    },
    "api/process-bulletin.js": {
      "maxDuration": 60
    },
    "api/parse-resume.js": {
      "maxDuration": 30
    },
    "api/match-mentors.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/apostolate/:id",     "destination": "/api/share?type=apostolate&id=:id" },
    { "source": "/parish/:id",         "destination": "/api/share?type=parish&id=:id" },
    { "source": "/business/:id",       "destination": "/api/share?type=business&id=:id" },
    { "source": "/school/:id",         "destination": "/api/share?type=school&id=:id" },
    { "source": "/campusministry/:id", "destination": "/api/share?type=campusministry&id=:id" },
    { "source": "/vocation/:id",       "destination": "/api/share?type=vocation&id=:id" },
    { "source": "/retreat/:id",        "destination": "/api/share?type=retreat&id=:id" },
    { "source": "/missionary/:id",     "destination": "/api/share?type=missionary&id=:id" },
    { "source": "/pilgrimage/:id",     "destination": "/api/share?type=pilgrimage&id=:id" }
  ]
}
